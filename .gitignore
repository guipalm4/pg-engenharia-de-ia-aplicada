# Node.js e JavaScript
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json  # Opcional: inclua se preferir yarn.lock; remova para npm lock
yarn.lock          # Comente se usar npm

# Ambientes e Configurações Locais
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.nyc_output
coverage/
.coverage

# Builds e Outputs Temporários (JS/TS)
dist/
build/
*.log
*.tmp
*.temp
out/

# IDEs e Editores
.vscode/settings.json
.vscode/tasks.json
.vscode/launch.json
.vscode/extensions.json
.idea/
*.swp
*.swo
*.sublime-*

# Sistemas Operacionais
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Thumbs.db:Encryptable

# Experimentos e Saídas de Execução (JS Scripts)
experiments/*.json  # Outputs temporários de runs (ex.: resultados de treinamento)
experiments/*.csv   # Se gerados dinamicamente
*.out
*.pid
*.seed
*.pid.lock

# Dados e Modelos Grandes (IA com JS: armazene externamente em Hugging Face, Kaggle ou Drive)
data/raw/*.csv      # Datasets brutos grandes (>100MB; use DVC ou links no README)
data/raw/*.json
data/processed/*.json
data/processed/*.pkl  # Se usar libs como ml-matrix
models/*.bin        # Pesos binários do TensorFlow.js (pesados)
models/weights.bin
models/*.h5         # Se integrar com TensorFlow (híbrido)
datasets/*.zip
datasets/*.tar.gz
*.joblib            # Serializações de objetos ML

# Arquivos de Backup e Temp
*~
*.bak
*.backup
*.tmp

# Git LFS (opcional: descomente se usar para arquivos médios, ~50-100MB)
# models/*.json filter=lfs diff=lfs merge=lfs -text
# data/large_dataset.json filter=lfs diff=lfs merge=lfs -text

# Ignorar arquivos sensíveis (PII, chaves)
*.key
*.pem
*.cert
*.keystore
secrets/
config/local/

**/docs/**
**/.tool-versions